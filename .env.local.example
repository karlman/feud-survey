# Copy to .env.local and fill in values

# PostgreSQL connection string
# Local dev: use docker-compose (see docker-compose.yml)
DATABASE_URL="postgresql://feud:feud@localhost:5432/feud_survey"

# Admin password for the /admin section
ADMIN_PASSWORD="changeme"

# Secret for signing session JWTs (generate a random string)
SESSION_SECRET="replace-with-a-long-random-string"

# Anthropic API key for AI tabulation
ANTHROPIC_API_KEY="sk-ant-..."

# Public URL of this app (used for QR code generation)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
